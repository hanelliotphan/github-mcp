                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "ref": {
                "type": "string",
                "minLength": 1
            },
            "task": {
                "type": "string"
            },
