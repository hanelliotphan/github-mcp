{
    "name": "github_list_repo_deployments",
    "description": "List deployments for a repository.",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "sha": {
                "type": "string"
            },
            "ref": {
                "type": "string"
            },
            "task": {
                "type": "string"
            },
            "environment": {
                "type": [
                    "string",
                    "null"
                ]
            },
            "per_page": {
                "type": "integer",
                "minimum": 1,
                "maximum": 100
            },
            "page": {
                "type": "integer",
                "minimum": 1
            },
            "all_pages": {
                "type": "boolean"
            },
            "max_pages": {
                "type": "integer",
                "minimum": 1,
                "maximum": 500
            }
        },
        "required": [
            "owner",
            "name"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
