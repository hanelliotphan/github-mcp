{
    "name": "github_create_or_update_repo_environment",
    "description": "Create or update an environment for a repository.",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "environment_name": {
                "type": "string",
                "minLength": 1
            },
            "wait_timer": {
                "type": "integer",
                "minimum": 0,
                "maximum": 43200
            },
            "prevent_self_review": {
                "type": "boolean"
            },
            "reviewers": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": [
                                "User",
                                "Team"
                            ]
                        },
                        "id": {
                            "type": "integer",
                            "minimum": 1
                        }
                    },
                    "required": [
                        "type",
                        "id"
                    ]
                }
            },
            "deployment_branch_policy": {
                "oneOf": [
                    {
                        "type": "object",
                        "properties": {
                            "protected_branches": {
                                "type": "boolean"
                            },
                            "custom_branch_policies": {
                                "type": "boolean"
                            }
                        },
                        "required": [
                            "protected_branches",
                            "custom_branch_policies"
                        ]
                    },
                    {
                        "type": "null"
                    }
                ]
            }
        },
        "required": [
            "owner",
            "name",
            "environment_name"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
