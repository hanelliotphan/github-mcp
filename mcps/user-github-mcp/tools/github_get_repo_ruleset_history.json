{
  "name": "github_get_repo_ruleset_history",
  "description": "List version history for a repository ruleset (GET /repos/{owner}/{repo}/rulesets/{ruleset_id}/history). Use ruleset_id from github_list_repo_rulesets. per_page 1-100 default 100, page, all_pages, max_pages. Each version has version_id, actor, updated_at. See GitHub REST repository rules.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "ruleset_id": {
        "type": "integer",
        "minimum": 1
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": ["owner", "name", "ruleset_id"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
