{
  "name": "github_create_commit_comment_reaction",
  "description": "Create reaction for a commit comment.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "comment_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "content": {
        "type": "string",
        "enum": [
          "+1",
          "-1",
          "laugh",
          "confused",
          "heart",
          "hooray",
          "rocket",
          "eyes"
        ]
      }
    },
    "required": [
      "owner",
      "name",
      "comment_id",
      "content"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
