{
  "name": "github_get_repo_installation_for_authenticated_app",
  "description": "GET /repos/{owner}/{repo}/installation — get the authenticated GitHub App installation for a repository. Requires JWT. MCP param name maps to API repo.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      }
    },
    "required": [
      "owner",
      "name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
