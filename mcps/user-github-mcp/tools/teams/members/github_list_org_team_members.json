{
  "name": "github_list_org_team_members",
  "description": "List team members (GET /orgs/{org}/teams/{team_slug}/members).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "team_slug": {
        "type": "string",
        "minLength": 1
      },
      "role": {
        "type": "string",
        "enum": [
          "member",
          "maintainer",
          "all"
        ]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "org",
      "team_slug"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
