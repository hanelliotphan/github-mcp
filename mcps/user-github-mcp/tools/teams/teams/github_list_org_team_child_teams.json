        "maxLength": 39
      },
      "team_slug": {
        "type": "string",
        "minLength": 1
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "org",
      "team_slug"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
