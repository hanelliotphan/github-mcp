{
  "name": "github_update_org_team",
  "description": "Update a team (PATCH /orgs/{org}/teams/{team_slug}).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "team_slug": {
        "type": "string",
        "minLength": 1
      },
      "team_name": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string"
      },
      "privacy": {
        "type": "string",
        "enum": [
          "secret",
          "closed"
        ]
      },
      "notification_setting": {
        "type": "string",
        "enum": [
          "notifications_enabled",
          "notifications_disabled"
        ]
      },
      "permission": {
        "type": "string",
        "enum": [
          "pull",
          "push",
          "admin"
        ]
      },
      "parent_team_id": {
        "type": [
          "integer",
          "null"
        ],
        "minimum": 1
      }
    },
    "required": [
      "org",
      "team_slug"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
