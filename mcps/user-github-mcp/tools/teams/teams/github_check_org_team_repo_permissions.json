{
  "name": "github_check_org_team_repo_permissions",
  "description": "Check team permissions for a repository (GET /orgs/{org}/teams/{team_slug}/repos/{owner}/{repo}).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "team_slug": {
        "type": "string",
        "minLength": 1
      },
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "required": [
      "org",
      "team_slug",
      "owner",
      "name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
