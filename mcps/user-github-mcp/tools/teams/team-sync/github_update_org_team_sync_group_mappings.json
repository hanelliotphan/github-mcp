{
  "name": "github_update_org_team_sync_group_mappings",
  "description": "Create or update IdP group connections for a team (PATCH /orgs/{org}/teams/{team_slug}/team-sync/group-mappings).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "team_slug": {
        "type": "string",
        "minLength": 1
      },
      "groups": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "group_id": {
              "type": "string",
              "minLength": 1
            },
            "group_name": {
              "type": "string",
              "minLength": 1
            },
            "group_description": {
              "type": "string"
            }
          },
          "required": [
            "group_id",
            "group_name",
            "group_description"
          ]
        }
      }
    },
    "required": [
      "org",
      "team_slug",
      "groups"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
