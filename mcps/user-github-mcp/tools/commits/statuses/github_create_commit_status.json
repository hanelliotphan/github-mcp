{
  "name": "github_create_commit_status",
  "description": "Create a commit status.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "sha": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "state": {
        "type": "string",
        "enum": [
          "error",
          "failure",
          "pending",
          "success"
        ]
      },
      "target_url": {
        "type": [
          "string",
          "null"
        ],
        "format": "uri"
      },
      "description": {
        "type": [
          "string",
          "null"
        ]
      },
      "context": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "owner",
      "name",
      "sha",
      "state"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
