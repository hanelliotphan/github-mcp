{
  "name": "github_compare_repo_commits",
  "description": "Compare two commits (GET /repos/{owner}/{repo}/compare/{basehead}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "base": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      },
      "head": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      }
    },
    "required": [
      "owner",
      "name",
      "base",
      "head"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
