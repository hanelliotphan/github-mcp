{
  "name": "github_list_branches_for_head_commit",
  "description": "List branches where a commit is HEAD.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "commit_sha": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "owner",
      "name",
      "commit_sha"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
