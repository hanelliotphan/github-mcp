        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "commit_sha": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "body": {
        "type": "string",
        "minLength": 1
      },
      "path": {
        "type": "string",
        "minLength": 1
      },
      "position": {
        "type": "integer"
      },
      "line": {
        "type": "integer"
      }
    },
    "required": [
      "owner",
      "name",
      "commit_sha",
      "body"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
