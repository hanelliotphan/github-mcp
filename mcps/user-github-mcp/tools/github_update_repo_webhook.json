{
  "name": "github_update_repo_webhook",
  "description": "Update a repository webhook (PATCH /repos/{owner}/{repo}/hooks/{hook_id}). Pass webhook with at least one of config, events (replaces list), add_events, remove_events, active. If secret was set before, resend same or new secret or it is removed. Classic tokens need write:repo_hook or repo. Returns 200. See GitHub REST repository webhooks.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "hook_id": {
        "type": "integer",
        "minimum": 1
      },
      "webhook": {
        "type": "object",
        "minProperties": 1,
        "properties": {
          "config": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "minLength": 1
              },
              "content_type": {
                "type": "string",
                "enum": ["json", "form"]
              },
              "secret": {
                "type": "string"
              },
              "insecure_ssl": {}
            },
            "additionalProperties": true
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "add_events": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "remove_events": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "active": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "required": ["owner", "name", "hook_id", "webhook"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
