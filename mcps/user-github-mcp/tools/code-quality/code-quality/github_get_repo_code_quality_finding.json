{
  "name": "github_get_repo_code_quality_finding",
  "description": "Get a code quality finding (GET /repos/{owner}/{repo}/code-quality/findings/{finding_number}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "finding_number": {
        "type": "integer",
        "exclusiveMinimum": 0
      }
    },
    "required": [
      "owner",
      "name",
      "finding_number"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
