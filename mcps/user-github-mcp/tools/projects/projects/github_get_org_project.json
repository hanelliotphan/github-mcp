{
  "name": "github_get_org_project",
  "description": "Get an organization-owned project (GET /orgs/{org}/projectsV2/{project_number}).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "project_number": {
        "type": "integer",
        "exclusiveMinimum": 0
      }
    },
    "required": [
      "org",
      "project_number"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
