{
  "name": "github_update_user_project_item",
  "description": "Update project item fields (PATCH /users/{username}/projectsV2/{project_number}/items/{item_id}).",
  "arguments": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "project_number": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "item_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "fields": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "value": {
              "type": [
                "string",
                "number",
                "null"
              ]
            }
          },
          "required": [
            "id",
            "value"
          ]
        }
      }
    },
    "required": [
      "username",
      "project_number",
      "item_id",
      "fields"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
