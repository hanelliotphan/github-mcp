{
  "name": "github_delete_org_project_item",
  "description": "Delete a project item (DELETE /orgs/{org}/projectsV2/{project_number}/items/{item_id}).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "project_number": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "item_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      }
    },
    "required": [
      "org",
      "project_number",
      "item_id"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
