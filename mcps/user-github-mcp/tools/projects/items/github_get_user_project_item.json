{
  "name": "github_get_user_project_item",
  "description": "Get an item on a user-owned project (GET /users/{username}/projectsV2/{project_number}/items/{item_id}).",
  "arguments": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "project_number": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "item_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "fields": {
        "type": "array",
        "items": {
          "type": "integer",
          "exclusiveMinimum": 0
        }
      }
    },
    "required": [
      "username",
      "project_number",
      "item_id"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
