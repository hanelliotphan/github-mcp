{
  "name": "github_create_org_project_draft_item",
  "description": "Create a draft issue item on an organization-owned project (POST /orgs/{org}/projectsV2/{project_number}/drafts).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "project_number": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "body": {
        "type": "string"
      }
    },
    "required": [
      "org",
      "project_number",
      "title"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
