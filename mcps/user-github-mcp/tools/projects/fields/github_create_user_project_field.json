{
  "name": "github_create_user_project_field",
  "description": "Add a field to a user-owned project (POST /users/{username}/projectsV2/{project_number}/fields).",
  "arguments": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "project_number": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "data_type": {
        "type": "string",
        "enum": [
          "text",
          "number",
          "date",
          "single_select",
          "iteration"
        ]
      },
      "issue_field_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "single_select_options": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "iteration_configuration": {
        "type": "object"
      }
    },
    "required": [
      "username",
      "project_number",
      "name",
      "data_type"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
