{
  "name": "github_update_enterprise_team",
  "description": "Update an enterprise team (PATCH /enterprises/{enterprise}/teams/{team_slug}).",
  "arguments": {
    "type": "object",
    "properties": {
      "enterprise": {
        "type": "string",
        "minLength": 1,
        "maxLength": 50
      },
      "team_slug": {
        "type": "string",
        "minLength": 1
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": [
          "string",
          "null"
        ]
      },
      "organization_selection_type": {
        "type": "string",
        "enum": [
          "disabled",
          "selected",
          "all"
        ]
      },
      "group_id": {
        "type": [
          "string",
          "null"
        ]
      },
      "notification_setting": {
        "type": "string",
        "enum": [
          "notifications_enabled",
          "notifications_disabled"
        ]
      },
      "sync_to_organizations": {
        "type": "string",
        "enum": [
          "all",
          "disabled"
        ]
      }
    },
    "required": [
      "enterprise",
      "team_slug"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
