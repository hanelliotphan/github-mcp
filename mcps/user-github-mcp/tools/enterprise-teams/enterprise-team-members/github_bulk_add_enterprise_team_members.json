{
  "name": "github_bulk_add_enterprise_team_members",
  "description": "Bulk add team members to an enterprise team (POST …/memberships/add).",
  "arguments": {
    "type": "object",
    "properties": {
      "enterprise": {
        "type": "string",
        "minLength": 1,
        "maxLength": 50
      },
      "enterprise_team": {
        "type": "string",
        "minLength": 1
      },
      "usernames": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1,
          "maxLength": 39
        },
        "minItems": 1
      }
    },
    "required": [
      "enterprise",
      "enterprise_team",
      "usernames"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
