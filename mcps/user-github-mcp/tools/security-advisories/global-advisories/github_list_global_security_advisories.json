{
  "name": "github_list_global_security_advisories",
  "description": "List global security advisories (GET /advisories).",
  "arguments": {
    "type": "object",
    "properties": {
      "ghsa_id": {
        "type": "string",
        "minLength": 1
      },
      "type": {
        "type": "string",
        "enum": [
          "reviewed",
          "malware",
          "unreviewed"
        ]
      },
      "cve_id": {
        "type": "string",
        "minLength": 1
      },
      "ecosystem": {
        "type": "string",
        "enum": [
          "rubygems",
          "npm",
          "pip",
          "maven",
          "nuget",
          "composer",
          "go",
          "rust",
          "erlang",
          "actions",
          "pub",
          "other",
          "swift"
        ]
      },
      "severity": {
        "type": "string",
        "enum": [
          "unknown",
          "low",
          "medium",
          "high",
          "critical"
        ]
      },
      "cwes": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      },
      "is_withdrawn": {
        "type": "boolean"
      },
      "affects": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      },
      "published": {
        "type": "string",
        "minLength": 1
      },
      "updated": {
        "type": "string",
        "minLength": 1
      },
      "modified": {
        "type": "string",
        "minLength": 1
      },
      "epss_percentage": {
        "type": "string",
        "minLength": 1
      },
      "epss_percentile": {
        "type": "string",
        "minLength": 1
      },
      "direction": {
        "type": "string",
        "enum": [
          "asc",
          "desc"
        ]
      },
      "sort": {
        "type": "string",
        "enum": [
          "updated",
          "published",
          "epss_percentage",
          "epss_percentile"
        ]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "before": {
        "type": "string"
      },
      "after": {
        "type": "string"
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
