{
  "name": "github_create_repo_security_advisory",
  "description": "Create a repository security advisory (POST /repos/{owner}/{repo}/security-advisories).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "summary": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024
      },
      "description": {
        "type": "string",
        "minLength": 1,
        "maxLength": 65535
      },
      "vulnerabilities": {
        "type": "array",
        "items": {
          "type": "object"
        },
        "minItems": 1
      },
      "cve_id": {
        "type": [
          "string",
          "null"
        ]
      },
      "cwe_ids": {
        "type": [
          "array",
          "null"
        ],
        "items": {
          "type": "string"
        }
      },
      "credits": {
        "type": [
          "array",
          "null"
        ],
        "items": {
          "type": "object"
        }
      },
      "severity": {
        "type": [
          "string",
          "null"
        ],
        "enum": [
          "critical",
          "high",
          "medium",
          "low",
          null
        ]
      },
      "cvss_vector_string": {
        "type": [
          "string",
          "null"
        ]
      },
      "start_private_fork": {
        "type": "boolean"
      }
    },
    "required": [
      "owner",
      "name",
      "summary",
      "description",
      "vulnerabilities"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
