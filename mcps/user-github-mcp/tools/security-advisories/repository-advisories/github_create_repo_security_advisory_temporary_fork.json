{
  "name": "github_create_repo_security_advisory_temporary_fork",
  "description": "Create a temporary private fork for a repository security advisory (POST /repos/{owner}/{repo}/security-advisories/{ghsa_id}/forks).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "ghsa_id": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "owner",
      "name",
      "ghsa_id"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
