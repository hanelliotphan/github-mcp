{
  "name": "github_list_repo_security_advisories",
  "description": "List repository security advisories (GET /repos/{owner}/{repo}/security-advisories).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "direction": {
        "type": "string",
        "enum": [
          "asc",
          "desc"
        ]
      },
      "sort": {
        "type": "string",
        "enum": [
          "created",
          "updated",
          "published"
        ]
      },
      "state": {
        "type": "string",
        "enum": [
          "triage",
          "draft",
          "published",
          "closed"
        ]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "before": {
        "type": "string"
      },
      "after": {
        "type": "string"
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "owner",
      "name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
