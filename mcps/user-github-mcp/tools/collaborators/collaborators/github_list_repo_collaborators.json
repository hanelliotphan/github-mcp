{
  "name": "github_list_repo_collaborators",
  "description": "List repository collaborators (GET /repos/{owner}/{repo}/collaborators).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "affiliation": {
        "type": "string",
        "enum": [
          "outside",
          "direct",
          "all"
        ]
      },
      "permission": {
        "type": "string",
        "enum": [
          "pull",
          "triage",
          "push",
          "maintain",
          "admin"
        ]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "owner",
      "name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
