{
  "name": "github_update_repo_invitation",
  "description": "Update a repository invitation.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "invitation_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "permissions": {
        "type": "string",
        "enum": [
          "read",
          "write",
          "maintain",
          "triage",
          "admin"
        ]
      }
    },
    "required": [
      "owner",
      "name",
      "invitation_id"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
