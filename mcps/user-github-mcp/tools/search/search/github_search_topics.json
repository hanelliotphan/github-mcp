{
  "name": "github_search_topics",
  "description": "Search topics.",
  "arguments": {
    "type": "object",
    "properties": {
      "q": {
        "type": "string",
        "minLength": 1
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      },
      "text_match": {
        "type": "boolean"
      }
    },
    "required": [
      "q"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
