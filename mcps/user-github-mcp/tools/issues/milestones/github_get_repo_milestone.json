{
    "name": "github_get_repo_milestone",
    "description": "Get a milestone (GET /repos/{owner}/{repo}/milestones/{milestone_number}). See [Get a milestone](https://docs.github.com/en/rest/issues/milestones?apiVersion=2026-03-10#get-a-milestone).",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "milestone_number": {
                "type": "integer",
                "minimum": 1
            }
        },
        "required": [
            "owner",
            "name",
            "milestone_number"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
