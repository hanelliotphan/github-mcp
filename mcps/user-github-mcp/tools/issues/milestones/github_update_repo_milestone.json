{
    "name": "github_update_repo_milestone",
    "description": "Update a milestone (PATCH /repos/{owner}/{repo}/milestones/{milestone_number}). See [Update a milestone](https://docs.github.com/en/rest/issues/milestones?apiVersion=2026-03-10#update-a-milestone).",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "milestone_number": {
                "type": "integer",
                "minimum": 1
            },
            "title": {
                "type": "string"
            },
            "state": {
                "type": "string",
                "enum": [
                    "open",
                    "closed"
                ]
            },
            "description": {
                "oneOf": [
                    {
                        "type": "string"
                    },
                    {
                        "type": "null"
                    }
                ]
            },
            "due_on": {
                "oneOf": [
                    {
                        "type": "string"
                    },
                    {
                        "type": "null"
                    }
                ]
            }
        },
        "required": [
            "owner",
            "name",
            "milestone_number"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
