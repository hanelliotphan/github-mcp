    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "comment_id": {
                "type": "integer",
                "minimum": 1
            }
        },
        "required": [
            "owner",
            "name",
            "comment_id"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
