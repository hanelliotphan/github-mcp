{
    "name": "github_create_issue_comment",
    "description": "Create an issue comment (POST /repos/{owner}/{repo}/issues/{issue_number}/comments). Success is HTTP 201. See [Create an issue comment](https://docs.github.com/en/rest/issues/comments?apiVersion=2026-03-10#create-an-issue-comment).",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "issue_number": {
                "type": "integer",
                "minimum": 1
            },
            "body": {
                "type": "string",
                "minLength": 1
            }
        },
        "required": [
            "owner",
            "name",
            "issue_number",
            "body"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
