{
    "name": "github_get_issue_parent",
    "description": "Get the parent issue (GET /repos/{owner}/{repo}/issues/{issue_number}/parent). See [Get the parent issue](https://docs.github.com/en/rest/issues/sub-issues?apiVersion=2026-03-10#get-the-parent-issue).",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "issue_number": {
                "type": "integer",
                "minimum": 1
            }
        },
        "required": [
            "owner",
            "name",
            "issue_number"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
