{
    "name": "github_delete_issue_field_value",
    "description": "Delete an issue field value (DELETE /repos/{owner}/{repo}/issues/{issue_number}/issue-field-values/{issue_field_id}). See [Delete an issue field value](https://docs.github.com/en/rest/issues/issue-field-values?apiVersion=2026-03-10#delete-an-issue-field-value).",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "issue_number": {
                "type": "integer",
                "minimum": 1
            },
            "issue_field_id": {
                "type": "integer",
                "minimum": 1
            }
        },
        "required": [
            "owner",
            "name",
            "issue_number",
            "issue_field_id"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
