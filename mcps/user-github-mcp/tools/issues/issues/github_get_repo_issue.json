{
    "name": "github_get_repo_issue",
    "description": "Get an issue (GET /repos/{owner}/{repo}/issues/{issue_number}). See [Get an issue](https://docs.github.com/en/rest/issues/issues?apiVersion=2026-03-10#get-an-issue).",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "issue_number": {
                "type": "integer",
                "minimum": 1
            }
        },
        "required": [
            "owner",
            "name",
            "issue_number"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
