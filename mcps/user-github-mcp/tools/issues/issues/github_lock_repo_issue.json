{
    "name": "github_lock_repo_issue",
    "description": "Lock an issue (PUT /repos/{owner}/{repo}/issues/{issue_number}/lock). Optional lock_reason. Returns HTTP 204. See [Lock an issue](https://docs.github.com/en/rest/issues/issues?apiVersion=2026-03-10#lock-an-issue).",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "issue_number": {
                "type": "integer",
                "minimum": 1
            },
            "lock_reason": {
                "type": "string",
                "enum": [
                    "off-topic",
                    "too heated",
                    "resolved",
                    "spam"
                ]
            }
        },
        "required": [
            "owner",
            "name",
            "issue_number"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
