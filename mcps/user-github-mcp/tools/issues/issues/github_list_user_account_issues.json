{
    "name": "github_list_user_account_issues",
    "description": "List issues for the authenticated user across owned and member repositories (GET /user/issues). Page pagination. See [List user account issues](https://docs.github.com/en/rest/issues/issues?apiVersion=2026-03-10#list-user-account-issues).",
    "arguments": {
        "type": "object",
        "properties": {
            "filter": {
                "type": "string",
                "enum": [
                    "assigned",
                    "created",
                    "mentioned",
                    "subscribed",
                    "repos",
                    "all"
                ]
            },
            "state": {
                "type": "string",
                "enum": [
                    "open",
                    "closed",
                    "all"
                ]
            },
            "labels": {
                "type": "string"
            },
            "sort": {
                "type": "string",
                "enum": [
                    "created",
                    "updated",
                    "comments"
                ]
            },
            "direction": {
                "type": "string",
                "enum": [
                    "asc",
                    "desc"
                ]
            },
            "since": {
                "type": "string"
            },
            "per_page": {
                "type": "integer",
                "minimum": 1,
                "maximum": 100
            },
            "page": {
                "type": "integer",
                "minimum": 1
            },
            "all_pages": {
                "type": "boolean"
            },
            "max_pages": {
                "type": "integer",
                "minimum": 1,
                "maximum": 500
            }
        },
        "required": [],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
