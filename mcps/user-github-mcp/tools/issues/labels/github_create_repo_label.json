{
    "name": "github_create_repo_label",
    "description": "Create a label (POST /repos/{owner}/{repo}/labels). MCP label_name maps to API name. Success is HTTP 201. See [Create a label](https://docs.github.com/en/rest/issues/labels?apiVersion=2026-03-10#create-a-label).",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "label_name": {
                "type": "string",
                "minLength": 1
            },
            "color": {
                "type": "string"
            },
            "description": {
                "type": "string"
            }
        },
        "required": [
            "owner",
            "name",
            "label_name"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
