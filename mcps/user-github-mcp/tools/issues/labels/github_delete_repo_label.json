{
    "name": "github_delete_repo_label",
    "description": "Delete a label (DELETE /repos/{owner}/{repo}/labels/{name}). MCP label_name maps to API name. See [Delete a label](https://docs.github.com/en/rest/issues/labels?apiVersion=2026-03-10#delete-a-label).",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "label_name": {
                "type": "string",
                "minLength": 1
            }
        },
        "required": [
            "owner",
            "name",
            "label_name"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
