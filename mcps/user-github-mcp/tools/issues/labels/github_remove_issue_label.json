{
    "name": "github_remove_issue_label",
    "description": "Remove a label from an issue (DELETE /repos/{owner}/{repo}/issues/{issue_number}/labels/{name}). MCP label_name maps to API name. See [Remove a label from an issue](https://docs.github.com/en/rest/issues/labels?apiVersion=2026-03-10#remove-a-label-from-an-issue).",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "issue_number": {
                "type": "integer",
                "minimum": 1
            },
            "label_name": {
                "type": "string",
                "minLength": 1
            }
        },
        "required": [
            "owner",
            "name",
            "issue_number",
            "label_name"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
