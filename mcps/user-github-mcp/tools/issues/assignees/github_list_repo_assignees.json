{
    "name": "github_list_repo_assignees",
    "description": "List assignees for a repository (GET /repos/{owner}/{repo}/assignees). Page pagination with per_page, page, all_pages, max_pages. See [List assignees](https://docs.github.com/en/rest/issues/assignees?apiVersion=2026-03-10#list-assignees).",
    "arguments": {
        "type": "object",
        "properties": {
            "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39
            },
            "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
            },
            "per_page": {
                "type": "integer",
                "minimum": 1,
                "maximum": 100
            },
            "page": {
                "type": "integer",
                "minimum": 1
            },
            "all_pages": {
                "type": "boolean"
            },
            "max_pages": {
                "type": "integer",
                "minimum": 1,
                "maximum": 500
            }
        },
        "required": [
            "owner",
            "name"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
    }
}
