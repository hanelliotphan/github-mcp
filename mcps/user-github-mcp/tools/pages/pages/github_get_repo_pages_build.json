{
  "name": "github_get_repo_pages_build",
  "description": "Get a GitHub Pages build by ID (GET /repos/{owner}/{repo}/pages/builds/{build_id}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "build_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      }
    },
    "$schema": "http://json-schema.org/draft-07/schema#",
    "required": [
      "owner",
      "name",
      "build_id"
    ]
  }
}
