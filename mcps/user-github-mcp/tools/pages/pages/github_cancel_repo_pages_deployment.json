{
  "name": "github_cancel_repo_pages_deployment",
  "description": "Cancel a GitHub Pages deployment (POST /repos/{owner}/{repo}/pages/deployments/{pages_deployment_id}/cancel). Success is typically HTTP **204**.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "pages_deployment_id": {
        "anyOf": [
          {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      }
    },
    "$schema": "http://json-schema.org/draft-07/schema#",
    "required": [
      "owner",
      "name",
      "pages_deployment_id"
    ]
  }
}
