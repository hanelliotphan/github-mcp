{
  "name": "github_create_repo_pages_site",
  "description": "Create/configure a GitHub Pages site (POST /repos/{owner}/{repo}/pages). Optional **build_type** (`legacy`|`workflow`) and **source** ({branch, path}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "build_type": {
        "type": "string",
        "enum": [
          "legacy",
          "workflow"
        ]
      },
      "source": {
        "type": "object",
        "properties": {
          "branch": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "enum": [
              "/",
              "/docs"
            ]
          }
        },
        "required": [
          "branch"
        ]
      }
    },
    "$schema": "http://json-schema.org/draft-07/schema#",
    "required": [
      "owner",
      "name"
    ]
  }
}
