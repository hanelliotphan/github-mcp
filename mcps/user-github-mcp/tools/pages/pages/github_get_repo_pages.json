{
  "name": "github_get_repo_pages",
  "description": "Get a GitHub Pages site for a repository (GET /repos/{owner}/{repo}/pages).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "$schema": "http://json-schema.org/draft-07/schema#",
    "required": [
      "owner",
      "name"
    ]
  }
}
