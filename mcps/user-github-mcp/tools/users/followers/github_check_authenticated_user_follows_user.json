{
  "name": "github_check_authenticated_user_follows_user",
  "description": "GET /user/following/{username}",
  "arguments": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      }
    },
    "required": [
      "username"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
