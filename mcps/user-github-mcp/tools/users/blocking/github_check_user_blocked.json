{
  "name": "github_check_user_blocked",
  "description": "GET /user/blocks/{username} — check if user is blocked (204→blocked:true, 404→blocked:false).",
  "arguments": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      }
    },
    "required": ["username"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
