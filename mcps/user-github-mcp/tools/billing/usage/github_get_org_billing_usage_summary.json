{
  "name": "github_get_org_billing_usage_summary",
  "description": "\"Get billing usage summary for an organization (GET /organizations/{org}/settings/billing/usage/summary).  Public preview. Only the past 24 months are available. Optional filters: repository, product,",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "year": {
        "type": "integer",
        "minimum": 2000,
        "maximum": 2100
      },
      "month": {
        "type": "integer",
        "minimum": 1,
        "maximum": 12
      },
      "day": {
        "type": "integer",
        "minimum": 1,
        "maximum": 31
      },
      "repository": {
        "type": "string"
      },
      "product": {
        "type": "string"
      },
      "sku": {
        "type": "string"
      }
    },
    "required": [
      "org"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
