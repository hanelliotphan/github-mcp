{
  "name": "github_get_user_premium_request_billing_usage",
  "description": "\"Get premium request billing usage for a user (GET /users/{username}/settings/billing/premium_request/usage).  See [Get billing premium request usage report for a user](https://docs.github.com/en/rest",
  "arguments": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "year": {
        "type": "integer",
        "minimum": 2000,
        "maximum": 2100
      },
      "month": {
        "type": "integer",
        "minimum": 1,
        "maximum": 12
      },
      "day": {
        "type": "integer",
        "minimum": 1,
        "maximum": 31
      },
      "model": {
        "type": "string"
      },
      "product": {
        "type": "string"
      }
    },
    "required": [
      "username"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
