{
  "name": "github_get_org_advanced_security_active_committers",
  "description": "Get GitHub Advanced Security active committers for an organization (GET /orgs/{org}/settings/billing/advanced-security). Optional advanced_security_product; supports per_page/page/all_pages.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "advanced_security_product": {
        "type": "string",
        "enum": [
          "code_security",
          "secret_protection"
        ]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "org"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
