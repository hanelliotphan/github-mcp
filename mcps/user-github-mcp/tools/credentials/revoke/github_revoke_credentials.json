{
  "name": "github_revoke_credentials",
  "description": "Revoke a list of credentials (POST /credentials/revoke). Must be unauthenticated; max 1000 tokens per request.",
  "arguments": {
    "type": "object",
    "properties": {
      "credentials": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1,
        "maxItems": 1000
      }
    },
    "required": [
      "credentials"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
