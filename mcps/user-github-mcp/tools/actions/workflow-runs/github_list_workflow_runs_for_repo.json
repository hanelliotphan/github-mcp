{
  "name": "github_list_workflow_runs_for_repo",
  "description": "List all workflow runs for a repository (GET /repos/{owner}/{repo}/actions/runs). Returns total_count and workflow_runs. Optional filters actor, branch, event, status, created, check_suite_id, head_sha, exclude_pull_requests. per_page 1-100 default 30, page, all_pages, max_pages. Classic tokens need repo scope for private repositories. See GitHub REST workflow runs.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": { "type": "string", "minLength": 1, "maxLength": 39, "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$" },
      "name": { "type": "string", "minLength": 1, "maxLength": 100, "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$" },
      "actor": { "type": "string" },
      "branch": { "type": "string" },
      "event": { "type": "string" },
      "status": { "type": "string", "enum": ["completed", "action_required", "cancelled", "failure", "neutral", "skipped", "stale", "success", "timed_out", "in_progress", "queued", "requested", "waiting", "pending"] },
      "created": { "type": "string" },
      "exclude_pull_requests": { "type": "boolean" },
      "check_suite_id": { "type": "integer", "minimum": 1 },
      "head_sha": { "type": "string" },
      "per_page": { "type": "integer", "minimum": 1, "maximum": 100 },
      "page": { "type": "integer", "minimum": 1 },
      "all_pages": { "type": "boolean" },
      "max_pages": { "type": "integer", "minimum": 1, "maximum": 500 }
    },
    "required": ["owner", "name"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
