{
  "name": "github_list_actions_caches",
  "description": "List GitHub Actions caches for a repository (GET /repos/{owner}/{repo}/actions/caches). Returns total_count and actions_caches (id, ref, key, version, last_accessed_at, created_at, size_in_bytes). Optional ref, key, sort (created_at|last_accessed_at|size_in_bytes), direction (asc|desc). per_page 1-100 default 100, page, all_pages, max_pages. Classic tokens need repo scope for private repos. See GitHub REST Actions cache.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "ref": {
        "type": "string",
        "minLength": 1
      },
      "key": {
        "type": "string",
        "minLength": 1
      },
      "sort": {
        "type": "string",
        "enum": ["created_at", "last_accessed_at", "size_in_bytes"]
      },
      "direction": {
        "type": "string",
        "enum": ["asc", "desc"]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": ["owner", "name"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
