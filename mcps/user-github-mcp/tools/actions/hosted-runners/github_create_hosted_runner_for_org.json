{
  "name": "github_create_hosted_runner_for_org",
  "description": "Create a GitHub-hosted runner for an organization (POST /orgs/{org}/actions/hosted-runners). Requires name, image (id, source, version), size, runner_group_id. Optional maximum_runners, enable_static_ip, image_gen. Success is HTTP 201. Classic tokens need manage_runners:org scope. See GitHub REST Actions hosted runners.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": { "type": "string", "minLength": 1, "maxLength": 64 },
      "image": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "enum": ["github", "partner", "custom"] },
          "version": { "type": ["string", "null"] }
        }
      },
      "size": { "type": "string", "minLength": 1 },
      "runner_group_id": { "type": "integer" },
      "maximum_runners": { "type": "integer" },
      "enable_static_ip": { "type": "boolean" },
      "image_gen": { "type": "boolean" }
    },
    "required": ["org", "name", "image", "size", "runner_group_id"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
