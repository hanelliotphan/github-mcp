{
  "name": "github_update_hosted_runner_for_org",
  "description": "Update a GitHub-hosted runner for an organization (PATCH /orgs/{org}/actions/hosted-runners/{hosted_runner_id}). Optional name, runner_group_id, maximum_runners, enable_static_ip, size, image_source, image_id, image_version, image_gen. Classic tokens need manage_runners:org scope. See GitHub REST Actions hosted runners.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "hosted_runner_id": { "type": "integer", "minimum": 1 },
      "name": { "type": "string", "minLength": 1, "maxLength": 64 },
      "runner_group_id": { "type": "integer" },
      "maximum_runners": { "type": "integer" },
      "enable_static_ip": { "type": "boolean" },
      "size": { "type": "string", "minLength": 1 },
      "image_source": { "type": "string", "enum": ["github", "partner", "custom"] },
      "image_id": { "type": "string", "minLength": 1 },
      "image_version": { "type": ["string", "null"] },
      "image_gen": { "type": "boolean" }
    },
    "required": ["org", "hosted_runner_id"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
