{
  "name": "github_list_workflow_run_artifacts",
  "description": "List GitHub Actions artifacts for a workflow run (GET /repos/{owner}/{repo}/actions/runs/{run_id}/artifacts). Returns total_count and artifacts. Optional artifact_name filters by exact name; direction asc|desc (default desc). per_page 1-100 default 100, page, all_pages, max_pages. Classic tokens need repo scope for private repos. See GitHub REST Actions artifacts.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "run_id": {
        "type": "integer",
        "minimum": 1
      },
      "artifact_name": {
        "type": "string",
        "minLength": 1
      },
      "direction": {
        "type": "string",
        "enum": ["asc", "desc"]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": ["owner", "name", "run_id"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
