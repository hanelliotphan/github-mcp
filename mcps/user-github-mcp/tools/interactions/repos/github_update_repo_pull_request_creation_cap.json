{
  "name": "github_update_repo_pull_request_creation_cap",
  "description": "Update the pull request creation cap (PATCH /repos/{owner}/{repo}/interaction-limits/pulls/creation-cap).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "enabled": {
        "type": "boolean"
      },
      "max_open_pull_requests": {
        "type": "integer",
        "minimum": 1,
        "maximum": 1000
      }
    },
    "required": [
      "owner",
      "name",
      "enabled"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
