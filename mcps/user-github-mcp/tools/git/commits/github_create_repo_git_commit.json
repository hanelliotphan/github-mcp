{
  "name": "github_create_repo_git_commit",
  "description": "Create a Git commit object (POST /repos/{owner}/{repo}/git/commits).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "message": {
        "type": "string",
        "minLength": 1
      },
      "tree": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      },
      "parents": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "author": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "email": { "type": "string", "minLength": 3 },
          "date": { "type": "string" }
        },
        "required": ["name", "email"]
      },
      "committer": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "email": { "type": "string", "minLength": 3 },
          "date": { "type": "string" }
        }
      },
      "signature": {
        "type": "string"
      }
    },
    "required": ["owner", "name", "message", "tree"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
