{
  "name": "github_get_repo_git_commit",
  "description": "Get a Git commit object (GET /repos/{owner}/{repo}/git/commits/{commit_sha}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "commit_sha": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      }
    },
    "required": ["owner", "name", "commit_sha"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
