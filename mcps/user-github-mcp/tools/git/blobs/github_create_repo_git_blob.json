{
  "name": "github_create_repo_git_blob",
  "description": "Create a Git blob object (POST /repos/{owner}/{repo}/git/blobs).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "content": {
        "type": "string",
        "minLength": 1
      },
      "encoding": {
        "type": "string",
        "enum": ["utf-8", "base64"]
      }
    },
    "required": ["owner", "name", "content"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
