{
  "name": "github_get_repo_git_tree",
  "description": "Get a Git tree object (GET /repos/{owner}/{repo}/git/trees/{tree_sha}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "tree_sha": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      },
      "recursive": {
        "type": ["boolean", "string", "number", "null"]
      }
    },
    "required": ["owner", "name", "tree_sha"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
