{
  "name": "github_get_repo_git_ref",
  "description": "Get a single Git reference (GET /repos/{owner}/{repo}/git/ref/{ref}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "ref": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      }
    },
    "required": ["owner", "name", "ref"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
