{
  "name": "github_list_repo_git_matching_refs",
  "description": "List matching Git references (GET /repos/{owner}/{repo}/git/matching-refs/{ref}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "ref": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      }
    },
    "required": ["owner", "name", "ref"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
