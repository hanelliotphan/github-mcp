{
  "name": "github_list_org_code_scanning_dismissal_requests",
  "description": "List dismissal requests for code scanning alerts for an organization (GET /orgs/{org}/dismissal-requests/code-scanning).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "repository_name": {
        "type": "string",
        "minLength": 1
      },
      "reviewer": {
        "type": "string",
        "minLength": 1
      },
      "requester": {
        "type": "string",
        "minLength": 1
      },
      "time_period": {
        "type": "string",
        "enum": [
          "hour",
          "day",
          "week",
          "month"
        ]
      },
      "request_status": {
        "type": "string",
        "enum": [
          "open",
          "approved",
          "expired",
          "denied",
          "all"
        ]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "org"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
