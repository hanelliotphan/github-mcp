{
  "name": "github_delete_codeql_database",
  "description": "Delete a CodeQL database (DELETE /repos/{owner}/{repo}/code-scanning/codeql/databases/{language}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "language": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "owner",
      "name",
      "language"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
