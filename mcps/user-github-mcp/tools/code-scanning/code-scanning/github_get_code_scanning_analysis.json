{
  "name": "github_get_code_scanning_analysis",
  "description": "Get a code scanning analysis (GET /repos/{owner}/{repo}/code-scanning/analyses/{analysis_id}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "analysis_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      }
    },
    "required": [
      "owner",
      "name",
      "analysis_id"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
