{
  "name": "github_list_code_scanning_alert_instances",
  "description": "List instances of a code scanning alert (GET /repos/{owner}/{repo}/code-scanning/alerts/{alert_number}/instances).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "alert_number": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "ref": {
        "type": "string"
      },
      "pr": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "owner",
      "name",
      "alert_number"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
