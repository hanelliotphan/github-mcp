{
  "name": "github_list_codeql_databases",
  "description": "List CodeQL databases for a repository (GET /repos/{owner}/{repo}/code-scanning/codeql/databases).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "required": [
      "owner",
      "name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
