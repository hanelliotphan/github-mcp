{
  "name": "github_get_code_scanning_alert",
  "description": "Get a code scanning alert (GET /repos/{owner}/{repo}/code-scanning/alerts/{alert_number}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "alert_number": {
        "type": "integer",
        "exclusiveMinimum": 0
      }
    },
    "required": [
      "owner",
      "name",
      "alert_number"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
