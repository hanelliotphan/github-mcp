{
  "name": "github_update_code_scanning_alert",
  "description": "Update a code scanning alert (PATCH /repos/{owner}/{repo}/code-scanning/alerts/{alert_number}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "alert_number": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "state": {
        "type": "string",
        "enum": [
          "open",
          "dismissed"
        ]
      },
      "dismissed_reason": {
        "type": [
          "string",
          "null"
        ]
      },
      "dismissed_comment": {
        "type": [
          "string",
          "null"
        ]
      },
      "create_request": {
        "type": "boolean"
      }
    },
    "required": [
      "owner",
      "name",
      "alert_number",
      "state"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
