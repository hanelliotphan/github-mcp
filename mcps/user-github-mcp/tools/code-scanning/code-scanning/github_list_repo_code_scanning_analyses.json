{
  "name": "github_list_repo_code_scanning_analyses",
  "description": "List code scanning analyses for a repository (GET /repos/{owner}/{repo}/code-scanning/analyses).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "tool_name": {
        "type": "string"
      },
      "tool_guid": {
        "type": "string"
      },
      "pr": {
        "type": "integer"
      },
      "ref": {
        "type": "string"
      },
      "sarif_id": {
        "type": "string"
      },
      "direction": {
        "type": "string",
        "enum": [
          "asc",
          "desc"
        ]
      },
      "sort": {
        "type": "string",
        "enum": [
          "created"
        ]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "owner",
      "name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
