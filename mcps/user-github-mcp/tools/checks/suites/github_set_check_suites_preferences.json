{
  "name": "github_set_check_suites_preferences",
  "description": "Update repository preferences for check suites (PATCH /repos/{owner}/{repo}/check-suites/preferences).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "auto_trigger_checks": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "app_id": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "setting": {
              "type": "boolean"
            }
          },
          "required": [
            "app_id",
            "setting"
          ]
        }
      }
    },
    "required": [
      "owner",
      "name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
