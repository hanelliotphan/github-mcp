{
  "name": "github_list_user_codespaces",
  "description": "List codespaces for the authenticated user (GET /user/codespaces). Optional repository_id filter. See GitHub REST Codespaces.",
  "arguments": {
    "type": "object",
    "properties": {
      "repository_id": {
        "type": "integer"
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}