{
  "name": "github_create_or_update_repo_codespaces_secret",
  "description": "Create or update repository codespaces secret with encrypted value. See GitHub REST repository secrets.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "secret_name": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      }
    },
    "required": [
      "owner",
      "name",
      "secret_name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}