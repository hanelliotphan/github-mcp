{
  "name": "github_list_repo_codespace_machines",
  "description": "List machine types for a repository codespace (GET /repos/{owner}/{repo}/codespaces/machines). Optional location, client_ip, ref. See GitHub REST Codespaces.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "location": {
        "type": "string"
      },
      "client_ip": {
        "type": "string"
      },
      "ref": {
        "type": "string"
      }
    },
    "required": [
      "owner",
      "name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}