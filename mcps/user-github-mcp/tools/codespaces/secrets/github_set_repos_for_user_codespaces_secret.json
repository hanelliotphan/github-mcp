{
  "name": "github_set_repos_for_user_codespaces_secret",
  "description": "Set repositories for user codespaces secret. See GitHub REST secrets.",
  "arguments": {
    "type": "object",
    "properties": {
      "secret_name": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "selected_repository_ids": {
        "type": "array",
        "items": {
          "type": "integer"
        }
      }
    },
    "required": [
      "secret_name",
      "selected_repository_ids"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}