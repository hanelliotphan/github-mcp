{
  "name": "github_remove_repo_from_user_codespaces_secret",
  "description": "Remove repository from user codespaces secret. See GitHub REST secrets.",
  "arguments": {
    "type": "object",
    "properties": {
      "secret_name": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "repository_id": {
        "type": "integer",
        "minimum": 1
      }
    },
    "required": [
      "secret_name",
      "repository_id"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}