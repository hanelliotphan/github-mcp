{
  "name": "github_create_or_update_user_codespaces_secret",
  "description": "Create or update user codespaces secret with optional selected_repository_ids. See GitHub REST secrets.",
  "arguments": {
    "type": "object",
    "properties": {
      "secret_name": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "value": {
        "type": "string"
      },
      "selected_repository_ids": {
        "type": "array",
        "items": {
          "type": "integer"
        }
      }
    },
    "required": [
      "secret_name",
      "value"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}