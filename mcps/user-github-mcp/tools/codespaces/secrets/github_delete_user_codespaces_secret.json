{
  "name": "github_delete_user_codespaces_secret",
  "description": "Delete user codespaces secret. See GitHub REST secrets.",
  "arguments": {
    "type": "object",
    "properties": {
      "secret_name": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      }
    },
    "required": [
      "secret_name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}