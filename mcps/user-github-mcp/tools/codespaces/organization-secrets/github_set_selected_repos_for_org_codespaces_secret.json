{
  "name": "github_set_selected_repos_for_org_codespaces_secret",
  "description": "Set selected repositories for organization codespaces secret. See GitHub REST organization secrets.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "secret_name": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "selected_repository_ids": {
        "type": "array",
        "items": {
          "type": "integer"
        }
      }
    },
    "required": [
      "org",
      "secret_name",
      "selected_repository_ids"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}