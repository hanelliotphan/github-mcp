{
  "name": "github_delete_org_codespaces_secret",
  "description": "Delete organization codespaces secret (DELETE /orgs/{org}/codespaces/secrets/{secret_name}). See GitHub REST organization secrets.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "secret_name": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      }
    },
    "required": [
      "org",
      "secret_name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}