{
  "name": "github_remove_selected_repo_from_org_codespaces_secret",
  "description": "Remove repository from organization codespaces secret. See GitHub REST organization secrets.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "secret_name": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "repository_id": {
        "type": "integer",
        "minimum": 1
      }
    },
    "required": [
      "org",
      "secret_name",
      "repository_id"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}