{
  "name": "github_create_or_update_org_codespaces_secret",
  "description": "Create or update organization codespaces secret (PUT /orgs/{org}/codespaces/secrets/{secret_name}). Plaintext value, visibility all|private|selected. See GitHub REST organization secrets.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "secret_name": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "value": {
        "type": "string"
      },
      "visibility": {
        "type": "string",
        "enum": [
          "all",
          "private",
          "selected"
        ]
      },
      "selected_repository_ids": {
        "type": "array",
        "items": {
          "type": "integer"
        }
      }
    },
    "required": [
      "org",
      "secret_name",
      "value",
      "visibility"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}