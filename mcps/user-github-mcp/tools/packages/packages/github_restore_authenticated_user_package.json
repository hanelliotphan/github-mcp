{
  "name": "github_restore_authenticated_user_package",
  "description": "Restore a deleted package for the authenticated user (POST /user/packages/{package_type}/{package_name}/restore). Optional **token**. Success is HTTP **204**.",
  "arguments": {
    "type": "object",
    "properties": {
      "package_type": {
        "type": "string",
        "enum": [
          "npm",
          "maven",
          "rubygems",
          "docker",
          "nuget",
          "container"
        ]
      },
      "package_name": {
        "type": "string",
        "minLength": 1
      },
      "token": {
        "type": "string",
        "minLength": 1
      }
    },
    "$schema": "http://json-schema.org/draft-07/schema#",
    "required": [
      "package_type",
      "package_name"
    ]
  }
}
