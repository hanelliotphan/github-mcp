{
  "name": "github_get_org_package",
  "description": "Get a package in an organization (GET /orgs/{org}/packages/{package_type}/{package_name}).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "package_type": {
        "type": "string",
        "enum": [
          "npm",
          "maven",
          "rubygems",
          "docker",
          "nuget",
          "container"
        ]
      },
      "package_name": {
        "type": "string",
        "minLength": 1
      }
    },
    "$schema": "http://json-schema.org/draft-07/schema#",
    "required": [
      "org",
      "package_type",
      "package_name"
    ]
  }
}
