{
  "name": "github_upload_repo_release_asset",
  "description": "Upload a release asset (POST /repos/{owner}/{repo}/releases/{release_id}/assets).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "release_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "asset_name": {
        "type": "string",
        "minLength": 1
      },
      "data_base64": {
        "type": "string",
        "minLength": 1
      },
      "label": {
        "type": "string"
      },
      "content_type": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "owner",
      "name",
      "release_id",
      "asset_name",
      "data_base64"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
