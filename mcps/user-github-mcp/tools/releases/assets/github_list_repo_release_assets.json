{
  "name": "github_list_repo_release_assets",
  "description": "List release assets (GET /repos/{owner}/{repo}/releases/{release_id}/assets).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "release_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "owner",
      "name",
      "release_id"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
