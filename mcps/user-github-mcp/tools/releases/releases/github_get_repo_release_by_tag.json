{
  "name": "github_get_repo_release_by_tag",
  "description": "Get a release by tag name (GET /repos/{owner}/{repo}/releases/tags/{tag}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "tag": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "owner",
      "name",
      "tag"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
