{
  "name": "github_generate_repo_release_notes",
  "description": "Generate release notes content (POST /repos/{owner}/{repo}/releases/generate-notes).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "tag_name": {
        "type": "string",
        "minLength": 1
      },
      "target_commitish": {
        "type": "string",
        "minLength": 1
      },
      "previous_tag_name": {
        "type": "string",
        "minLength": 1
      },
      "configuration_file_path": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "owner",
      "name",
      "tag_name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
