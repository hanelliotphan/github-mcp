{
  "name": "github_update_repo_release",
  "description": "Update a release (PATCH /repos/{owner}/{repo}/releases/{release_id}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "release_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "tag_name": {
        "type": "string",
        "minLength": 1
      },
      "target_commitish": {
        "type": "string",
        "minLength": 1
      },
      "release_name": {
        "type": "string",
        "minLength": 1
      },
      "body": {
        "type": "string"
      },
      "draft": {
        "type": "boolean"
      },
      "prerelease": {
        "type": "boolean"
      },
      "make_latest": {
        "type": "string",
        "enum": [
          "true",
          "false",
          "legacy"
        ]
      },
      "discussion_category_name": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "owner",
      "name",
      "release_id"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
