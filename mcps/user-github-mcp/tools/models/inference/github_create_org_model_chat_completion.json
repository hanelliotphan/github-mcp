{
  "name": "github_create_org_model_chat_completion",
  "description": "Run a chat completion attributed to an organization (POST /orgs/{org}/inference/chat/completions on models.github.ai).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "model": {
        "type": "string",
        "minLength": 1
      },
      "messages": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "role": {
              "type": "string",
              "enum": [
                "assistant",
                "developer",
                "system",
                "user"
              ]
            },
            "content": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "role",
            "content"
          ]
        },
        "minItems": 1
      },
      "frequency_penalty": {
        "type": "number",
        "minimum": -2,
        "maximum": 2
      },
      "max_tokens": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "modalities": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "text",
            "audio"
          ]
        }
      },
      "presence_penalty": {
        "type": "number",
        "minimum": -2,
        "maximum": 2
      },
      "response_format": {
        "type": "object",
        "additionalProperties": {}
      },
      "seed": {
        "type": "integer"
      },
      "stream": {
        "type": "boolean"
      },
      "stream_options": {
        "type": "object",
        "properties": {
          "include_usage": {
            "type": "boolean"
          }
        }
      },
      "stop": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "temperature": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "tool_choice": {
        "type": "string",
        "enum": [
          "auto",
          "required",
          "none"
        ]
      },
      "tools": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "top_p": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "api_version": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "org",
      "model",
      "messages"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
