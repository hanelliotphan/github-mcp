{
  "name": "github_create_enterprise_code_security_configuration",
  "description": "Create a code security configuration for an enterprise.",
  "arguments": {
    "type": "object",
    "properties": {
      "enterprise": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string",
        "minLength": 1
      },
      "advanced_security": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "code_security",
          "secret_protection"
        ]
      },
      "code_security": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "dependency_graph": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "dependency_graph_autosubmit_action": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "dependency_graph_autosubmit_action_options": {
        "type": "object",
        "properties": {
          "labeled_runners": {
            "type": "boolean"
          }
        }
      },
      "dependabot_alerts": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "dependabot_security_updates": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "dependabot_delegated_alert_dismissal": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "code_scanning_options": {
        "type": "object",
        "properties": {
          "allow_advanced": {
            "type": [
              "boolean",
              "null"
            ]
          }
        }
      },
      "code_scanning_default_setup": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "code_scanning_default_setup_options": {
        "type": "object",
        "properties": {
          "runner_type": {
            "type": "string",
            "enum": [
              "standard",
              "labeled",
              "not_set"
            ]
          },
          "runner_label": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "code_scanning_delegated_alert_dismissal": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "secret_protection": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "secret_scanning": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "secret_scanning_push_protection": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "secret_scanning_delegated_bypass": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "secret_scanning_delegated_bypass_options": {
        "type": "object"
      },
      "secret_scanning_validity_checks": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "secret_scanning_non_provider_patterns": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "secret_scanning_generic_secrets": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "secret_scanning_delegated_alert_dismissal": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "secret_scanning_extended_metadata": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "private_vulnerability_reporting": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled",
          "not_set"
        ]
      },
      "enforcement": {
        "type": "string",
        "enum": [
          "enforced",
          "unenforced"
        ]
      }
    },
    "required": [
      "enterprise",
      "name",
      "description"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
