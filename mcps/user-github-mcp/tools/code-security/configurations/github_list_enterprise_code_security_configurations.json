      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "before": {
        "type": "string"
      },
      "after": {
        "type": "string"
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "enterprise"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
