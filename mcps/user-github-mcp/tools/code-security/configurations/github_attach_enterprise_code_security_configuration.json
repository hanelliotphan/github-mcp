{
  "name": "github_attach_enterprise_code_security_configuration",
  "description": "Attach an enterprise code security configuration to repositories.",
  "arguments": {
    "type": "object",
    "properties": {
      "enterprise": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "configuration_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "scope": {
        "type": "string",
        "enum": [
          "all",
          "all_without_configurations"
        ]
      }
    },
    "required": [
      "enterprise",
      "configuration_id",
      "scope"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
