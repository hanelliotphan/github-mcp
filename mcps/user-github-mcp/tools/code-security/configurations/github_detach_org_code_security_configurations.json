{
  "name": "github_detach_org_code_security_configurations",
  "description": "Detach code security configurations from repositories.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "selected_repository_ids": {
        "type": "array",
        "items": {
          "type": "integer"
        },
        "minItems": 1,
        "maxItems": 250
      }
    },
    "required": [
      "org",
      "selected_repository_ids"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
