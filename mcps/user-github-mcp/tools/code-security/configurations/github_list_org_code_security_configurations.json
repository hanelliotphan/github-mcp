{
  "name": "github_list_org_code_security_configurations",
  "description": "List code security configurations for an organization (GET /orgs/{org}/code-security/configurations).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "target_type": {
        "type": "string",
        "enum": [
          "global",
          "all"
        ]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "before": {
        "type": "string"
      },
      "after": {
        "type": "string"
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "org"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
