{
  "name": "github_set_enterprise_code_security_configuration_as_default",
  "description": "Set an enterprise code security configuration as default.",
  "arguments": {
    "type": "object",
    "properties": {
      "enterprise": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "configuration_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "default_for_new_repos": {
        "type": "string",
        "enum": [
          "all",
          "none",
          "private_and_internal",
          "public"
        ]
      }
    },
    "required": [
      "enterprise",
      "configuration_id"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
