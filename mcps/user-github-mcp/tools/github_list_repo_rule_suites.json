{
  "name": "github_list_repo_rule_suites",
  "description": "List ruleset evaluation history for a repository (GET /repos/{owner}/{repo}/rulesets/rule-suites; ruleset insights, not ruleset definitions). Optional ref, time_period (hour, day default, week, month), actor_name, rule_suite_result (pass, fail, bypass, all default). Use per_page (1-100, default 100 when omitted) and page. Set all_pages to follow next links up to max_pages (default 100). See GitHub REST docs for repository rulesets / rule suites.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "ref": {
        "type": "string",
        "minLength": 1
      },
      "time_period": {
        "type": "string",
        "enum": ["hour", "day", "week", "month"]
      },
      "actor_name": {
        "type": "string",
        "minLength": 1
      },
      "rule_suite_result": {
        "type": "string",
        "enum": ["pass", "fail", "bypass", "all"]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": ["owner", "name"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
