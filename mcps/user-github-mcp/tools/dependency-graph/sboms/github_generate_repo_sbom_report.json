{
  "name": "github_generate_repo_sbom_report",
  "description": "Request generation of an SBOM for a repository (GET /repos/{owner}/{repo}/dependency-graph/sbom/generate-report).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "required": [
      "owner",
      "name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
