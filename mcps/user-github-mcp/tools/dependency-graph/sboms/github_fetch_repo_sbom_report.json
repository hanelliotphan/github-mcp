{
  "name": "github_fetch_repo_sbom_report",
  "description": "Fetch a previously generated SBOM report (GET /repos/{owner}/{repo}/dependency-graph/sbom/fetch-report/{sbom_uuid}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "sbom_uuid": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "owner",
      "name",
      "sbom_uuid"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
