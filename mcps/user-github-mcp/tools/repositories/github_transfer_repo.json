{
  "name": "github_transfer_repo",
  "description": "Transfer a repository to another user or organization (POST /repos/{owner}/{repo}/transfer). Returns HTTP 202; personal-repo transfers may require acceptance by the new owner and complete asynchronously. Requires admin access; classic PATs need `repo` scope. See [Transfer a repository](https://docs.github.com/en/rest/repos/repos?apiVersion=2026-03-10#transfer-a-repository).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "new_owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "new_name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "team_ids": {
        "maxItems": 50,
        "type": "array",
        "items": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "dry_run": {
        "default": false,
        "type": "boolean"
      },
      "confirm": {
        "default": false,
        "type": "boolean"
      }
    },
    "required": [
      "owner",
      "name",
      "new_owner"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}