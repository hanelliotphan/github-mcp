{
  "name": "github_list_repo_rulesets",
  "description": "List repository rulesets (GET /repos/{owner}/{repo}/rulesets). Optional includes_parents (default true on API) for org/enterprise rulesets; optional targets comma-separated (e.g. branch,tag,push). bypass_actors only with write access. per_page 1-100 default 100, page, all_pages, max_pages. See GitHub REST docs for repository rules.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "includes_parents": {
        "type": "boolean"
      },
      "targets": {
        "type": "string",
        "minLength": 1
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": ["owner", "name"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
