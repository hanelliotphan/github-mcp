{
  "name": "github_update_pull_request_review_protection",
  "description": "Update pull request review protection (PATCH .../required_pull_request_reviews).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "branch": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      },
      "dismissal_restrictions": {
        "type": "object"
      },
      "dismiss_stale_reviews": {
        "type": "boolean"
      },
      "require_code_owner_reviews": {
        "type": "boolean"
      },
      "required_approving_review_count": {
        "type": "integer",
        "minimum": 0,
        "maximum": 6
      },
      "require_last_push_approval": {
        "type": "boolean"
      },
      "bypass_pull_request_allowances": {
        "type": "object"
      }
    },
    "required": [
      "owner",
      "name",
      "branch"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
