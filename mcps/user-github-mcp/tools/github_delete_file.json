{
  "name": "github_delete_file",
  "description": "Delete a file in a repository (DELETE /repos/{owner}/{repo}/contents/{path}). Requires the file blob sha (e.g. from github_get_repo_content). Classic tokens need repo scope; deleting under .github/workflows also requires workflow scope. Do not run this and github_create_update_file_contents concurrently for the same path. See GitHub REST docs for repository contents.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "path": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4096
      },
      "message": {
        "type": "string",
        "minLength": 1,
        "maxLength": 65536
      },
      "sha": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      },
      "branch": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      },
      "committer": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 200 },
          "email": { "type": "string", "minLength": 3, "maxLength": 320 }
        },
        "required": ["name", "email"]
      },
      "author": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 200 },
          "email": { "type": "string", "minLength": 3, "maxLength": 320 }
        },
        "required": ["name", "email"]
      }
    },
    "required": [
      "owner",
      "name",
      "path",
      "message",
      "sha"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
