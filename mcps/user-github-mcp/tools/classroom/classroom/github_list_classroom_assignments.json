{
  "name": "github_list_classroom_assignments",
  "description": "List assignments for a GitHub Classroom (GET /classrooms/{classroom_id}/assignments). Closing down after 2026-08-28.",
  "arguments": {
    "type": "object",
    "properties": {
      "classroom_id": {
        "type": "integer",
        "exclusiveMinimum": 0
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "classroom_id"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
