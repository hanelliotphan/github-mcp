{
  "name": "github_create_repo_deploy_key",
  "description": "Create a deploy key for a repository (POST /repos/{owner}/{repo}/keys).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "key": {
        "type": "string",
        "minLength": 1
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "read_only": {
        "type": "boolean"
      }
    },
    "required": [
      "owner",
      "name",
      "key"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
