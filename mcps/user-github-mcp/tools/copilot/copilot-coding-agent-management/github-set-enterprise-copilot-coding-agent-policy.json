{
  "name": "github_set_enterprise_copilot_coding_agent_policy",
  "description": "Set the Copilot cloud agent policy for an enterprise (PUT /enterprises/{enterprise}/copilot/policies/coding_agent).",
  "arguments": {
    "type": "object",
    "properties": {
      "enterprise": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "policy_state": {
        "type": "string",
        "enum": [
          "enabled_for_all_orgs",
          "disabled_for_all_orgs",
          "enabled_for_selected_orgs",
          "configured_by_org_admins"
        ]
      }
    },
    "required": [
      "enterprise",
      "policy_state"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}