{
  "name": "github_set_org_copilot_coding_agent_repositories",
  "description": "Replace selected repositories enabled for Copilot cloud agent (PUT /orgs/{org}/copilot/coding-agent/permissions/repositories).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "selected_repository_ids": {
        "type": "array",
        "items": {
          "type": "integer",
          "minimum": 1
        },
        "minItems": 1
      }
    },
    "required": [
      "org",
      "selected_repository_ids"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}