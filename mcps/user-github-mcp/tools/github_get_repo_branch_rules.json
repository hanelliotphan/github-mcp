{
  "name": "github_get_repo_branch_rules",
  "description": "List active rules that apply to a branch name (GET /repos/{owner}/{repo}/rules/branches/{branch}). Branch need not exist. Only active rulesets; rules from repo/org/enterprise. Use per_page (1-100, default 100) and page; set all_pages for next links up to max_pages (default 100). See GitHub REST docs for repository rules.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
      },
      "branch": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": ["owner", "name", "branch"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
