{
  "name": "github_get_org_private_registry",
  "description": "Get one organization private registry configuration (GET /orgs/{org}/private-registries/{secret_name}).",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "secret_name": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "org",
      "secret_name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
