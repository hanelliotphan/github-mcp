{
  "name": "github_get_org_ruleset_history",
  "description": "GET /orgs/{org}/rulesets/{ruleset_id}/history — list version history for an organization ruleset (version_id, actor, updated_at). ruleset_id from github_list_org_rulesets. page/per_page (default 100), all_pages + max_pages. HTTP 200.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "ruleset_id": {
        "type": "integer",
        "minimum": 1
      },
      "per_page": { "type": "integer", "minimum": 1, "maximum": 100 },
      "page": { "type": "integer", "minimum": 1 },
      "all_pages": { "type": "boolean" },
      "max_pages": { "type": "integer", "minimum": 1, "maximum": 500 }
    },
    "required": ["org", "ruleset_id"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
