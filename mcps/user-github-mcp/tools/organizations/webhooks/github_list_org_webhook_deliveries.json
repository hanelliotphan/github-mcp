{
  "name": "github_list_org_webhook_deliveries",
  "description": "List deliveries for an organization webhook (GET /orgs/{org}/hooks/{hook_id}/deliveries). Cursor pagination: per_page 1-100 default 100, cursor, optional status success|failure, all_pages and max_pages. Requires org owner; classic tokens need admin:org_hook. See GitHub REST organization webhooks.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "hook_id": {
        "type": "integer",
        "minimum": 1
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "cursor": {
        "type": "string",
        "minLength": 1
      },
      "status": {
        "type": "string",
        "enum": ["success", "failure"]
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": ["org", "hook_id"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
