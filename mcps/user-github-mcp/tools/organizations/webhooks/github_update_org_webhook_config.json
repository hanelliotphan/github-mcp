{
  "name": "github_update_org_webhook_config",
  "description": "Update webhook configuration only for an organization (PATCH /orgs/{org}/hooks/{hook_id}/config). Pass config with at least one of url, content_type, secret, insecure_ssl. Does not change events or active (use github_update_org_webhook). Requires org owner; classic tokens need admin:org_hook. Returns 200.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "hook_id": {
        "type": "integer",
        "minimum": 1
      },
      "config": {
        "type": "object",
        "minProperties": 1,
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1
          },
          "content_type": {
            "type": "string",
            "enum": ["json", "form"]
          },
          "secret": {
            "type": "string"
          },
          "insecure_ssl": {}
        },
        "additionalProperties": true
      }
    },
    "required": ["org", "hook_id", "config"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
