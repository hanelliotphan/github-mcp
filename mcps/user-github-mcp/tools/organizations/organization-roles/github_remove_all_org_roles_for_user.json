{
  "name": "github_remove_all_org_roles_for_user",
  "description": "DELETE /orgs/{org}/organization-roles/users/{username} — revoke all assigned organization roles from a user. Requires org admin; classic tokens need admin:org. HTTP 204 No Content.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "username": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      }
    },
    "required": ["org", "username"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
