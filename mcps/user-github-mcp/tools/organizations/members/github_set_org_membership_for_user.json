{
  "name": "github_set_org_membership_for_user",
  "description": "PUT /orgs/{org}/memberships/{username} — add or update org membership (role admin or member; default member). Org owners only. HTTP 200 returns membership object. See GitHub REST org members.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "username": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "role": {
        "type": "string",
        "enum": ["admin", "member"]
      }
    },
    "required": ["org", "username"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
