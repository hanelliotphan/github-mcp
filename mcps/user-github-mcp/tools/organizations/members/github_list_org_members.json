{
  "name": "github_list_org_members",
  "description": "GET /orgs/{org}/members — list org members (Simple User). Optional filter (2fa_disabled, 2fa_insecure, all) and role (all, admin, member). Pagination per_page/page or all_pages. HTTP 200. See GitHub REST org members.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "filter": {
        "type": "string",
        "enum": ["2fa_disabled", "2fa_insecure", "all"]
      },
      "role": {
        "type": "string",
        "enum": ["all", "admin", "member"]
      },
      "per_page": { "type": "integer", "minimum": 1, "maximum": 100 },
      "page": { "type": "integer", "minimum": 1 },
      "all_pages": { "type": "boolean" },
      "max_pages": { "type": "integer", "minimum": 1, "maximum": 500 }
    },
    "required": ["org"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
