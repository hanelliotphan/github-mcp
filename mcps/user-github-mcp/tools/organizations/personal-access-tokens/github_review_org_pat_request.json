{
  "name": "github_review_org_pat_request",
  "description": "POST /orgs/{org}/personal-access-token-requests/{pat_request_id} — approve or deny one pending fine-grained PAT access request. GitHub Apps only. action (approve/deny), optional reason (max 1024 chars). HTTP 204.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "pat_request_id": {
        "type": "integer",
        "minimum": 1
      },
      "action": {
        "type": "string",
        "enum": ["approve", "deny"]
      },
      "reason": {
        "type": "string",
        "maxLength": 1024
      }
    },
    "required": ["org", "pat_request_id", "action"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
