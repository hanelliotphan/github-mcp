{
  "name": "github_review_org_pat_requests",
  "description": "POST /orgs/{org}/personal-access-token-requests — approve or deny multiple pending fine-grained PAT access requests. GitHub Apps only. action (approve/deny), pat_request_ids (1-100 ids), optional reason (max 1024 chars). HTTP 202 Accepted.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "action": {
        "type": "string",
        "enum": ["approve", "deny"]
      },
      "pat_request_ids": {
        "type": "array",
        "items": { "type": "integer", "minimum": 1 },
        "minItems": 1,
        "maxItems": 100
      },
      "reason": {
        "type": "string",
        "maxLength": 1024
      }
    },
    "required": ["org", "action"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
