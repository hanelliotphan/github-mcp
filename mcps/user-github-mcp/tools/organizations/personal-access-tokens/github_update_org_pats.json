{
  "name": "github_update_org_pats",
  "description": "POST /orgs/{org}/personal-access-tokens — revoke org members' access via fine-grained PATs (action: revoke only). GitHub Apps only. pat_ids required. HTTP 202 Accepted.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "action": {
        "type": "string",
        "enum": ["revoke"]
      },
      "pat_ids": {
        "type": "array",
        "items": { "type": "integer", "minimum": 1 },
        "minItems": 1
      }
    },
    "required": ["org", "action", "pat_ids"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
