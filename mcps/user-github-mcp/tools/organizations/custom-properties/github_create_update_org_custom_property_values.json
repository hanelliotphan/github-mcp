{
  "name": "github_create_update_org_custom_property_values",
  "description": "PATCH /orgs/{org}/properties/values — set custom property values on up to 30 org repos at once (repository_names + properties with property_name/value; value null unsets). HTTP 204 typical. custom_properties_org_values_editor or org admin. 422 on validation/rate limit. See GitHub REST org custom properties.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "repository_names": {
        "type": "array",
        "minItems": 1,
        "maxItems": 30,
        "items": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^(?![.-])[A-Za-z0-9._-]{1,100}(?<![.-])$"
        },
        "description": "Short repo names under the org (max 30 per GitHub request)."
      },
      "properties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["property_name", "value"],
          "properties": {
            "property_name": { "type": "string", "minLength": 1, "maxLength": 255 },
            "value": {
              "oneOf": [
                { "type": "string" },
                { "type": "array", "items": { "type": "string" } },
                { "type": "null" }
              ]
            }
          }
        }
      }
    },
    "required": ["org", "repository_names", "properties"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
