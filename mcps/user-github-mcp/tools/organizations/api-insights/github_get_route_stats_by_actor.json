{
  "name": "github_get_route_stats_by_actor",
  "description": "GET /orgs/{org}/insights/api/route-stats/{actor_type}/{actor_id} — API Insights route-level request stats for an actor. Requires min_timestamp (ISO 8601); optional max_timestamp, pagination, filters, all_pages.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "actor_type": {
        "type": "string",
        "enum": [
          "installation",
          "classic_pat",
          "fine_grained_pat",
          "oauth_app",
          "github_app_user_to_server"
        ]
      },
      "actor_id": { "type": "integer", "minimum": 1 },
      "min_timestamp": { "type": "string", "minLength": 1 },
      "max_timestamp": { "type": "string", "minLength": 1 },
      "per_page": { "type": "integer", "minimum": 1, "maximum": 100 },
      "page": { "type": "integer", "minimum": 1 },
      "direction": { "type": "string", "enum": ["asc", "desc"] },
      "sort": { "type": "array", "items": { "type": "string", "minLength": 1 }, "maxItems": 20 },
      "api_route_substring": { "type": "string", "minLength": 1 },
      "all_pages": { "type": "boolean" },
      "max_pages": { "type": "integer", "minimum": 1, "maximum": 500 }
    },
    "required": ["org", "actor_type", "actor_id", "min_timestamp"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
