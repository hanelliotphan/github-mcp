{
  "name": "github_get_user_stats",
  "description": "GET /orgs/{org}/insights/api/user-stats/{user_id} — API Insights: one user's API usage broken down by actor (installation, PAT, OAuth app, etc.). Requires min_timestamp (ISO 8601); optional max_timestamp, actor_name_substring, direction, sort, pagination, all_pages.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "user_id": { "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "integer", "minimum": 1 }] },
      "min_timestamp": { "type": "string", "minLength": 1 },
      "max_timestamp": { "type": "string", "minLength": 1 },
      "per_page": { "type": "integer", "minimum": 1, "maximum": 100 },
      "page": { "type": "integer", "minimum": 1 },
      "direction": { "type": "string", "enum": ["asc", "desc"] },
      "sort": { "type": "array", "items": { "type": "string", "minLength": 1 }, "maxItems": 20 },
      "actor_name_substring": { "type": "string", "minLength": 1 },
      "all_pages": { "type": "boolean" },
      "max_pages": { "type": "integer", "minimum": 1, "maximum": 500 }
    },
    "required": ["org", "user_id", "min_timestamp"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
