{
  "name": "github_list_org_network_configurations",
  "description": "GET /orgs/{org}/settings/network-configurations — list hosted compute network configs (total_count, network_configurations). Classic tokens need read:network_configurations. Pagination: page, per_page 1-100 default 100; all_pages and max_pages.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 9007199254740991
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": ["org"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
