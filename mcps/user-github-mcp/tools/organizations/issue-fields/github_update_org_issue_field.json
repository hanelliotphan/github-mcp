{
  "name": "github_update_org_issue_field",
  "description": "PATCH /orgs/{org}/issue-fields/{issue_field_id} — update org issue field (at least one of name, description, visibility, options). For single_select, options replaces all options; include id on options to keep/update. Org admin; classic PAT admin:org. HTTP 200. See GitHub REST org issue fields.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "issue_field_id": { "type": "integer", "minimum": 1 },
      "name": { "type": "string", "minLength": 1 },
      "description": { "type": ["string", "null"] },
      "visibility": {
        "type": "string",
        "enum": ["organization_members_only", "all"]
      },
      "options": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "color", "priority"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "integer", "minimum": 1 },
            "name": { "type": "string", "minLength": 1 },
            "description": { "type": ["string", "null"] },
            "color": {
              "type": "string",
              "enum": ["gray", "blue", "green", "yellow", "orange", "red", "pink", "purple"]
            },
            "priority": { "type": "integer" }
          }
        }
      }
    },
    "required": ["org", "issue_field_id"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
