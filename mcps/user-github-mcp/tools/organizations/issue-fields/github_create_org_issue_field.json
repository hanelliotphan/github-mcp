{
  "name": "github_create_org_issue_field",
  "description": "POST /orgs/{org}/issue-fields — create an org issue field (name, data_type text|date|single_select|number; single_select requires options with name, color, priority). Optional description, visibility. Org admin; classic PAT admin:org. HTTP 200. See GitHub REST org issue fields.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": { "type": "string", "minLength": 1 },
      "description": { "type": ["string", "null"] },
      "data_type": {
        "type": "string",
        "enum": ["text", "date", "single_select", "number"]
      },
      "visibility": {
        "type": "string",
        "enum": ["organization_members_only", "all"]
      },
      "options": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "color", "priority"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "description": { "type": ["string", "null"] },
            "color": {
              "type": "string",
              "enum": ["gray", "blue", "green", "yellow", "orange", "red", "pink", "purple"]
            },
            "priority": { "type": "integer" }
          }
        }
      }
    },
    "required": ["org", "name", "data_type"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
