{
  "name": "github_create_org_issue_type",
  "description": "POST /orgs/{org}/issue-types — create an org issue type (required name, is_enabled; optional description, color). Org admin; classic PAT admin:org. HTTP 200. See GitHub REST org issue types.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": { "type": "string", "minLength": 1 },
      "is_enabled": { "type": "boolean" },
      "description": { "type": ["string", "null"] },
      "color": {
        "anyOf": [
          {
            "type": "string",
            "enum": ["gray", "blue", "green", "yellow", "orange", "red", "pink", "purple"]
          },
          { "type": "null" }
        ]
      }
    },
    "required": ["org", "name", "is_enabled"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
