{
  "name": "github_block_org_user",
  "description": "PUT /orgs/{org}/blocks/{username} — block user for the org (204). admin:org. 422 on validation/spam. See GitHub REST org blocking.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "username": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      }
    },
    "required": ["org", "username"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
