{
  "name": "github_set_org_cluster_deployment_records",
  "description": "POST /orgs/{org}/artifacts/metadata/deployment-record/cluster/{cluster} — bulk set deployment records for a cluster. Requires logical_environment and deployments[] (name, digest, deployment_name per entry; optional version, status, github_repository, tags, runtime_risks). Optional physical_environment, return_records. HTTP 200. See GitHub REST orgs deployment-record cluster endpoint.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "cluster": { "type": "string", "minLength": 1 },
      "logical_environment": { "type": "string", "minLength": 1 },
      "physical_environment": { "type": "string", "minLength": 1 },
      "return_records": { "type": "boolean" },
      "deployments": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "digest": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "status": { "type": "string", "enum": ["deployed", "decommissioned"] },
            "deployment_name": { "type": "string", "minLength": 1 },
            "github_repository": { "type": "string", "minLength": 1 },
            "tags": { "type": "object", "additionalProperties": { "type": "string" } },
            "runtime_risks": {
              "type": "array",
              "maxItems": 20,
              "items": {
                "type": "string",
                "enum": [
                  "critical-resource",
                  "internet-exposed",
                  "lateral-movement",
                  "sensitive-data"
                ]
              }
            }
          },
          "required": ["name", "digest", "deployment_name"]
        }
      }
    },
    "required": ["org", "cluster", "logical_environment", "deployments"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
