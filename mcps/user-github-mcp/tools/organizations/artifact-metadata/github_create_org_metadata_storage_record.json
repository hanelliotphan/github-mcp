{
  "name": "github_create_org_metadata_storage_record",
  "description": "POST /orgs/{org}/artifacts/metadata/storage-record — create a metadata storage record (name, digest, registry_url required; optional version, artifact_url, path, repository, status active|eol|deleted, github_repository, return_records). HTTP 200. See GitHub REST org artifact metadata.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39,
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$"
      },
      "name": { "type": "string", "minLength": 1 },
      "digest": { "type": "string", "minLength": 1 },
      "registry_url": { "type": "string", "minLength": 1 },
      "version": { "type": "string", "minLength": 1 },
      "artifact_url": { "type": "string", "minLength": 1 },
      "path": { "type": "string", "minLength": 1 },
      "repository": { "type": "string", "minLength": 1 },
      "status": { "type": "string", "enum": ["active", "eol", "deleted"] },
      "github_repository": { "type": "string", "minLength": 1 },
      "return_records": { "type": "boolean" }
    },
    "required": ["org", "name", "digest", "registry_url"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
