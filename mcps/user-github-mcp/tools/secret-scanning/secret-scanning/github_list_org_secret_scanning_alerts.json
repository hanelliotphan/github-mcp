{
  "name": "github_list_org_secret_scanning_alerts",
  "description": "List secret scanning alerts for an organization (GET /orgs/{org}/secret-scanning/alerts). Classic tokens need repo or security_events.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "state": {
        "type": "string",
        "enum": [
          "open",
          "resolved"
        ]
      },
      "secret_type": {
        "type": "string"
      },
      "exclude_secret_types": {
        "type": "string"
      },
      "exclude_providers": {
        "type": "string"
      },
      "providers": {
        "type": "string"
      },
      "resolution": {
        "type": "string"
      },
      "assignee": {
        "type": "string"
      },
      "sort": {
        "type": "string",
        "enum": [
          "created",
          "updated"
        ]
      },
      "direction": {
        "type": "string",
        "enum": [
          "asc",
          "desc"
        ]
      },
      "validity": {
        "type": "string"
      },
      "is_publicly_leaked": {
        "type": "boolean"
      },
      "is_multi_repo": {
        "type": "boolean"
      },
      "hide_secret": {
        "type": "boolean"
      },
      "is_bypassed": {
        "type": "boolean"
      },
      "included_metadata": {
        "type": "string"
      },
      "owner_email_hash": {
        "type": "string"
      },
      "before": {
        "type": "string"
      },
      "after": {
        "type": "string"
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "org"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
