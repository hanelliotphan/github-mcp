{
  "name": "github_update_secret_scanning_alert",
  "description": "Update a secret scanning alert (PATCH /repos/{owner}/{repo}/secret-scanning/alerts/{alert_number}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "alert_number": {
        "type": "integer",
        "minimum": 1
      },
      "state": {
        "type": "string",
        "enum": [
          "open",
          "resolved"
        ]
      },
      "resolution": {
        "type": [
          "string",
          "null"
        ],
        "enum": [
          "false_positive",
          "wont_fix",
          "revoked",
          "used_in_tests",
          null
        ]
      },
      "resolution_comment": {
        "type": [
          "string",
          "null"
        ]
      },
      "assignee": {
        "type": [
          "string",
          "null"
        ]
      },
      "validity": {
        "type": [
          "string",
          "null"
        ],
        "enum": [
          "active",
          "inactive",
          null
        ]
      }
    },
    "required": [
      "owner",
      "name",
      "alert_number",
      "state"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
