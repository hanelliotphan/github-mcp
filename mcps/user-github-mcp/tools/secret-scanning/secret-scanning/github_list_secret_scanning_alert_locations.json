{
  "name": "github_list_secret_scanning_alert_locations",
  "description": "List locations for a secret scanning alert (GET /repos/{owner}/{repo}/secret-scanning/alerts/{alert_number}/locations).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "alert_number": {
        "type": "integer",
        "minimum": 1
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "owner",
      "name",
      "alert_number"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
