{
  "name": "github_update_repo_secret_scanning_custom_pattern",
  "description": "Update custom pattern (PATCH /repos/{owner}/{repo}/secret-scanning/custom-patterns/{pattern_id}).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "pattern_id": {
        "type": "integer",
        "minimum": 1
      },
      "pattern": {
        "type": "string"
      },
      "start_delimiter": {
        "type": "string"
      },
      "end_delimiter": {
        "type": "string"
      },
      "must_match": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "must_not_match": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "custom_pattern_version": {
        "type": [
          "string",
          "null"
        ]
      }
    },
    "required": [
      "owner",
      "name",
      "pattern_id",
      "custom_pattern_version"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
