{
  "name": "github_list_repo_secret_scanning_custom_patterns",
  "description": "List secret scanning custom patterns for a repository (GET /repos/{owner}/{repo}/secret-scanning/custom-patterns). Classic tokens need repo or security_events.",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "state": {
        "type": "string",
        "enum": [
          "published",
          "unpublished"
        ]
      },
      "push_protection": {
        "type": "string",
        "enum": [
          "enabled",
          "disabled"
        ]
      },
      "sort": {
        "type": "string",
        "enum": [
          "created",
          "updated",
          "name"
        ]
      },
      "direction": {
        "type": "string",
        "enum": [
          "asc",
          "desc"
        ]
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "all_pages": {
        "type": "boolean"
      },
      "max_pages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "required": [
      "owner",
      "name"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
