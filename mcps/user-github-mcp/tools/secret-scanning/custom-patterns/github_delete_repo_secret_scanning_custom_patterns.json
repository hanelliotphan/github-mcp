{
  "name": "github_delete_repo_secret_scanning_custom_patterns",
  "description": "Bulk delete custom patterns (DELETE /repos/{owner}/{repo}/secret-scanning/custom-patterns).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "patterns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "pattern_id": {
              "type": "integer",
              "minimum": 1
            },
            "custom_pattern_version": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "pattern_id"
          ]
        }
      },
      "post_delete_action": {
        "type": "string",
        "enum": [
          "delete_alerts",
          "resolve_alerts"
        ]
      }
    },
    "required": [
      "owner",
      "name",
      "patterns"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
