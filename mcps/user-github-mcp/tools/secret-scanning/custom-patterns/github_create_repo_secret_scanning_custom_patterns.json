{
  "name": "github_create_repo_secret_scanning_custom_patterns",
  "description": "Bulk create custom patterns (POST /repos/{owner}/{repo}/secret-scanning/custom-patterns).",
  "arguments": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "patterns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "pattern": {
              "type": "string"
            },
            "start_delimiter": {
              "type": "string"
            },
            "end_delimiter": {
              "type": "string"
            },
            "must_match": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "must_not_match": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "name",
            "pattern"
          ]
        }
      }
    },
    "required": [
      "owner",
      "name",
      "patterns"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
