{
  "name": "github_update_org_secret_scanning_pattern_configurations",
  "description": "Update secret scanning pattern configurations for an organization (PATCH /orgs/{org}/secret-scanning/pattern-configurations). Classic tokens need write:org.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": {
        "type": "string",
        "minLength": 1,
        "maxLength": 39
      },
      "pattern_config_version": {
        "type": [
          "string",
          "null"
        ]
      },
      "provider_pattern_settings": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "token_type": {
              "type": "string"
            },
            "push_protection_setting": {
              "type": "string",
              "enum": [
                "not-set",
                "disabled",
                "enabled"
              ]
            }
          },
          "required": [
            "token_type",
            "push_protection_setting"
          ]
        }
      },
      "custom_pattern_settings": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "token_type": {
              "type": "string"
            },
            "custom_pattern_version": {
              "type": [
                "string",
                "null"
              ]
            },
            "push_protection_setting": {
              "type": "string",
              "enum": [
                "disabled",
                "enabled"
              ]
            }
          },
          "required": [
            "token_type",
            "push_protection_setting"
          ]
        }
      }
    },
    "required": [
      "org"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
