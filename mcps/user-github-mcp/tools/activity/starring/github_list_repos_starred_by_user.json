{
  "name": "github_list_repos_starred_by_user",
  "description": "List repositories a user has starred (GET /users/{username}/starred). sort created (default) or updated, direction asc or desc (default). per_page 1-100 default 30, page, all_pages, max_pages. See GitHub REST activity starring.",
  "arguments": {
    "type": "object",
    "properties": {
      "username": { "type": "string", "minLength": 1, "maxLength": 39, "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$" },
      "sort": { "type": "string", "enum": ["created", "updated"] },
      "direction": { "type": "string", "enum": ["asc", "desc"] },
      "per_page": { "type": "integer", "minimum": 1, "maximum": 100 },
      "page": { "type": "integer", "minimum": 1 },
      "all_pages": { "type": "boolean" },
      "max_pages": { "type": "integer", "minimum": 1, "maximum": 500 }
    },
    "required": ["username"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
