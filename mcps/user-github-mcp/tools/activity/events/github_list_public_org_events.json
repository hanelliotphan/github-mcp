{
  "name": "github_list_public_org_events",
  "description": "List public events for an organization (GET /orgs/{org}/events). Not real-time; latency 30s to 6h. per_page 1-100 default 30, page, all_pages, max_pages. See GitHub REST activity events.",
  "arguments": {
    "type": "object",
    "properties": {
      "org": { "type": "string", "minLength": 1, "maxLength": 39, "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9]|-(?=[A-Za-z0-9-]*[A-Za-z0-9])){0,38}$" },
      "per_page": { "type": "integer", "minimum": 1, "maximum": 100 },
      "page": { "type": "integer", "minimum": 1 },
      "all_pages": { "type": "boolean" },
      "max_pages": { "type": "integer", "minimum": 1, "maximum": 500 }
    },
    "required": ["org"],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}
